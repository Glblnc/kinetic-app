# Copie ce fichier en .env et complète les valeurs.
# Le .env réel ne doit jamais être committé (voir .gitignore).

# Clé secrète Django (génère-en une avec :
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=change-moi

# 1 en développement local, 0 en production (active alors HTTPS + cookies sécurisés).
DJANGO_DEBUG=1

# Hôtes autorisés, séparés par des virgules. En prod : ton domaine.
# Ex : DJANGO_ALLOWED_HOSTS=kinetic.exemple.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Laisse vide en local. Hors DEBUG, les cookies sécurisés s'activent
# automatiquement ; mets 0 seulement si tu testes en HTTP sans DEBUG.
# DJANGO_COOKIE_SECURE=1

# Origines de confiance pour le CSRF. En prod : l'URL HTTPS publique.
# Ex : DJANGO_CSRF_TRUSTED_ORIGINS=https://kinetic.exemple.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Production HTTPS :
# DJANGO_SECURE_SSL=1            # redirige HTTP -> HTTPS (laisse à 1 sauf si le proxy le fait)
# DJANGO_HSTS_SECONDS=31536000   # active HSTS (1 an) une fois le HTTPS validé

# Base de données en production (fournie par l'hébergeur). Remplace SQLite.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Clé API Claude — RESTE CÔTÉ SERVEUR, jamais envoyée au navigateur.
ANTHROPIC_API_KEY=sk-ant-...

# Modèle Claude utilisé par le coach.
KINETIC_MODEL=claude-opus-4-8

# Inscription publique. 1 = tout le monde peut créer un compte (site public).
# 0 = l'inscription se ferme dès qu'un compte existe (usage privé).
KINETIC_ALLOW_REGISTRATION=1

# PostgreSQL (optionnel). Si POSTGRES_DB est défini, il remplace SQLite.
# POSTGRES_DB=kinetic
# POSTGRES_USER=kinetic
# POSTGRES_PASSWORD=motdepasse
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
